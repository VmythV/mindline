{
  "name": "mindline",
  "version": "0.0.0",
  "private": true,
  "description": "思谱 Mindline · 思维导图 × AI 拆解 × 时间轴 团队协作平台",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run build --filter=@mindline/shared --filter=@mindline/db && turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md,yaml,yml}\"",
    "infra:up": "bash scripts/infra-up.sh",
    "infra:down": "bash scripts/infra-down.sh",
    "services:dev": "bash scripts/services-start.sh fg",
    "services:start": "bash scripts/services-start.sh bg",
    "services:stop": "bash scripts/services-stop.sh",
    "db:generate": "pnpm -C packages/db db:generate",
    "db:migrate": "pnpm -C packages/db db:migrate",
    "db:studio": "pnpm -C packages/db db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.0.0"
  }
}
