# ===== 应用 =====
NODE_ENV=development

# ===== Postgres =====
DATABASE_URL=postgres://mindline:mindline@localhost:5432/mindline

# ===== Redis（协同多实例广播 / 缓存 / 在线态）=====
REDIS_URL=redis://localhost:6379

# ===== MinIO（S3 兼容对象存储，附件）=====
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mindline
S3_SECRET_KEY=mindline123
S3_BUCKET=mindline

# ===== JWT 鉴权 =====
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# ===== 服务端口 =====
API_PORT=3001
COLLAB_PORT=3002
WEB_PORT=5173

# ===== AI 模型网关（M2，可选）=====
AI_GATEWAY_URL=
AI_GATEWAY_KEY=
