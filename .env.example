# ===== 应用 =====
NODE_ENV=development

# ===== 数据库驱动（sqlite | postgres，默认 sqlite）=====
# sqlite：无需任何中间件，数据存储在 packages/db/.dev.db
# postgres：需要运行 pnpm infra:up，并配置下方 DATABASE_URL
DB_DRIVER=sqlite

# SQLite 文件绝对路径（留空则自动定位到 packages/db/.dev.db）
SQLITE_PATH=

# ===== Postgres（DB_DRIVER=postgres 时启用）=====
DATABASE_URL=postgres://mindline:mindline@localhost:5432/mindline

# ===== 缓存驱动（memory | redis，默认 memory）=====
# memory：进程内 Map，重启丢失；适合单实例开发
# redis：需要运行 pnpm infra:up，并配置下方 REDIS_URL（M4+/M6 多实例广播使用）
CACHE_DRIVER=memory

# ===== Redis（CACHE_DRIVER=redis 时启用）=====
REDIS_URL=redis://localhost:6379

# ===== collab 协同服务多实例广播（M0.5）=====
# 设置后 apps/collab 启用 Hocuspocus Redis extension，跨实例同步 update + awareness（水平扩展）。
# 留空 = 单实例，本地开发零依赖。多实例部署时填 redis://[:password@]host:port[/db]。
# COLLAB_REDIS_URL=redis://localhost:6379

# ===== 对象存储驱动（local | s3，默认 local）=====
# local：文件写入 STORAGE_DIR 目录；适合本地开发
# s3：需要运行 pnpm infra:up，并配置下方 S3_* 变量（M4+ 附件功能使用）
STORAGE_DRIVER=local

# 本地存储目录（STORAGE_DRIVER=local 时，留空则自动在服务进程目录创建 .local-storage/）
STORAGE_DIR=

# ===== MinIO / S3（STORAGE_DRIVER=s3 时启用）=====
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=mindline
S3_SECRET_KEY=mindline123
S3_BUCKET=mindline

# ===== JWT 鉴权 =====
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# ===== 服务端口 =====
API_PORT=3001
COLLAB_PORT=3002
WEB_PORT=5173

# ===== AI 模型网关（M2，可选）=====
# 留空 → 服务端 stub 降级（返回示例子节点，便于无 key 演示）
AI_GATEWAY_URL=
AI_GATEWAY_KEY=
AI_GATEWAY_MODEL=
AI_GATEWAY_PROVIDER=
# 租户 AI 凭证（ai_provider_configs）的对称加密主密钥；生成：openssl rand -base64 32
# 缺失时用不安全的开发派生密钥（仅本地）；生产务必配置
AI_CONFIG_SECRET=
